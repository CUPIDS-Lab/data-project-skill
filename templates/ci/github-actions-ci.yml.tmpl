# Lightweight CI for a scaffolded data project.
# Runs on every pull request and push so problems are caught before review, per the collaborative-data-science workflow.
# The project may be Python or R, so the language-specific build steps below are commented out — uncomment the block that matches this repo.
# The template-token guard always runs regardless of language, because no scaffolded repo should ever ship unfilled placeholders.

name: ci

on:
  pull_request:
  push:

jobs:
  ci:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      # Guard: fail if any unfilled template token remains in the repo. We search for the literal
      # double-open-brace marker (written with bracket expressions so this file stays placeholder-free)
      # but skip GitHub Actions expressions (the dollar-prefixed brace form) so workflow templates that
      # legitimately reference secrets or inputs are not flagged as unfilled tokens.
      - name: Check for unfilled template tokens
        run: |
          if grep -rIn --exclude-dir=.git -P '(?<![$])[{][{]' .; then
            echo "::error::Unfilled template tokens found (see matches above). Fill or remove them before merging."
            exit 1
          fi
          echo "No unfilled template tokens found."

