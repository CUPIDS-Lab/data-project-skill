          {
            "typeName": "keyword",
            "typeClass": "compound",
            "multiple": true,
            "value": [
              {
                "keywordValue": {
                  "typeName": "keywordValue",
                  "typeClass": "primitive",
                  "multiple": false,
                  "value": "{{PROJECT_SLUG}}"
                }
              }
            ]
          }<!-- IF:UPDATING -->,
          {
            "typeName": "notesText",
            "typeClass": "primitive",
            "multiple": false,
            "value": "Updated {{UPDATE_FREQUENCY}}; each refresh is published as a new Dataverse version under one DOI — cite the version number and UNF you used (see DEPOSIT.md)."
          },
          {
