                },
                "timePeriodCoveredEnd": {
                  "typeName": "timePeriodCoveredEnd",
                  "typeClass": "primitive",
                  "multiple": false,
                  "value": "EDIT-END-YYYY-MM-DD"
                }
              }
            ]
          }<!-- /IF -->
        ]
